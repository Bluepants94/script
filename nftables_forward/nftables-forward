#!/usr/bin/env bash

# ============================================================
#  nftables 端口转发统一脚本（apply + watch + quota-maintain）
#  --apply             : 读取 rules.conf 并重建 nftables 规则（含 named quota）
#  --watch             : 域名解析并按需触发规则重建
#  --save-quota-state  : 持久化当前 quota 已用流量到本地状态文件
#  --maintain          : 到期清理 + 周期重置（必要时触发重建）
# ============================================================

export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH}"

CONFIG_DIR="/etc/nftables-forward"
CONFIG_FILE="${CONFIG_DIR}/rules.conf"
LOCK_FILE="${CONFIG_DIR}/rules.conf.lock"
QUOTA_STATE_FILE="${CONFIG_DIR}/quota.state"
CHAIN_PRE="NFTFWD-PRE"
CHAIN_POST="NFTFWD-POST"
TABLE_NAME="nftfwd"
FILTER_TABLE_NAME="nftfwd_filter"
FILTER_CHAIN_FWD="NFTFWD-FWD"
SCRIPT_SELF="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || true)"

GLOBAL_WATCH_ENABLED=1
MANUAL_MODE=0
change_records=()
NFT_RULE_LINES=()

# apply 用规则数组
rules_listen_ip=()
rules_src_port=()
rules_dst_port=()
rules_resolved_ip=()
rules_proto=()
rules_id=()
rules_quota_enable=()
rules_quota_bytes=()

declare -A QUOTA_USED_MAP
declare -A QUOTA_OBJ_ADDED_IP
declare -A QUOTA_OBJ_ADDED_IP6

log_watch() {
    command -v logger >/dev/null 2>&1 && logger -t nftables-forward "$1"
}

is_valid_ipv4() {
    local ip="$1"
    [[ "$ip" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]] || return 1
    IFS='.' read -r o1 o2 o3 o4 <<< "$ip"
    for o in "$o1" "$o2" "$o3" "$o4"; do
        [[ "$o" =~ ^[0-9]+$ ]] || return 1
        [[ "${#o}" -gt 1 && "$o" == 0* ]] && return 1
        [[ "$o" -ge 0 && "$o" -le 255 ]] || return 1
    done
    return 0
}

is_valid_ipv6() {
    [[ "$1" == *:* && "$1" =~ ^[0-9A-Fa-f:]+$ ]]
}

is_valid_ip() {
    is_valid_ipv4 "$1" || is_valid_ipv6 "$1"
}

sanitize_rule_id() {
    local rid="$1"
    rid=$(echo "$rid" | tr -c 'a-zA-Z0-9_' '_')
    [[ -z "$rid" ]] && rid="r_unknown"
    echo "$rid"
}

quota_name_by_rule_id() {
    local rid="$1"
    echo "q_$(sanitize_rule_id "$rid")"
}

read_global_watch_enabled() {
    [[ -f "$CONFIG_FILE" ]] || return 0
    local enabled
    enabled=$(grep -m1 '^GLOBAL_WATCH_ENABLED=' "$CONFIG_FILE" 2>/dev/null | cut -d'=' -f2)
    [[ "$enabled" == "0" || "$enabled" == "1" ]] && GLOBAL_WATCH_ENABLED="$enabled"
}

resolve_domain_ip() {
    local domain="$1" ip=""
    command -v dig >/dev/null 2>&1 || return 1

    local server type
    for server in 8.8.8.8 1.1.1.1; do
        for type in A AAAA; do
            ip=$(dig @"$server" "$type" "$domain" +short 2>/dev/null | head -n 1)
            if [[ "$type" == "A" ]]; then
                is_valid_ipv4 "$ip" && { echo "$ip"; return 0; }
            else
                is_valid_ipv6 "$ip" && { echo "$ip"; return 0; }
            fi
        done
    done
    return 1
}

parse_port_expr() {
    local expr="$1"
    if [[ "$expr" =~ ^[0-9]+$ ]]; then
        [[ "$expr" -ge 1 && "$expr" -le 65535 ]] && { echo "single|$expr|$expr"; return 0; }
        return 1
    fi
    if [[ "$expr" =~ ^([0-9]+)-([0-9]+)$ ]]; then
        local a="${BASH_REMATCH[1]}" b="${BASH_REMATCH[2]}"
        [[ "$a" -ge 1 && "$b" -le 65535 && "$a" -lt "$b" ]] && { echo "range|$a|$b"; return 0; }
        return 1
    fi
    return 1
}

load_quota_state_map() {
    QUOTA_USED_MAP=()
    [[ -f "$QUOTA_STATE_FILE" ]] || return 0

    local rid qname used saved
    while IFS='|' read -r rid qname used saved; do
        [[ -z "$rid" || "$rid" == \#* ]] && continue
        [[ "$used" =~ ^[0-9]+$ ]] || used=0
        QUOTA_USED_MAP["$rid"]="$used"
    done < "$QUOTA_STATE_FILE"
}

load_rules_for_apply() {
    [[ -f "$CONFIG_FILE" ]] || return 1

    rules_listen_ip=(); rules_src_port=(); rules_dst_port=(); rules_resolved_ip=(); rules_proto=()
    rules_id=(); rules_quota_enable=(); rules_quota_bytes=()

    while IFS='|' read -r c1 c2 c3 c4 c5 c6 c7 c8 c9 c10 c11 c12 c13 c14 c15 c16 c17; do
        [[ -z "$c1" || "$c1" == \#* || "$c1" =~ ^GLOBAL_ ]] && continue

        local listen_ip src_port dst_port resolved proto rid quota_enable quota_bytes

        if [[ -n "$c17" ]]; then
            listen_ip="$c1"; src_port="$c2"; dst_port="$c4"; proto="$c5"
            resolved="$c6"; is_valid_ip "$resolved" || resolved="$c3"
            rid="$c10"; quota_enable="$c11"; quota_bytes="$c12"
        elif [[ -n "$c9" ]]; then
            listen_ip="$c1"; src_port="$c2"; dst_port="$c4"; proto="$c5"
            resolved="$c6"; is_valid_ip "$resolved" || resolved="$c3"
            rid="r_legacy_${RANDOM}_$(date +%s%N)"; quota_enable=0; quota_bytes=0
        elif [[ -n "$c5" ]]; then
            listen_ip="$c1"; src_port="$c2"; dst_port="$c4"; proto="$c5"; resolved="$c3"
            rid="r_legacy_${RANDOM}_$(date +%s%N)"; quota_enable=0; quota_bytes=0
        elif [[ -n "$c4" ]]; then
            listen_ip="0.0.0.0"; src_port="$c1"; dst_port="$c3"; proto="$c4"; resolved="$c2"
            rid="r_legacy_${RANDOM}_$(date +%s%N)"; quota_enable=0; quota_bytes=0
        else
            continue
        fi

        is_valid_ip "$resolved" || continue
        [[ "$quota_enable" == "1" ]] || quota_enable=0
        [[ "$quota_bytes" =~ ^[0-9]+$ ]] || quota_bytes=0
        [[ -n "$rid" ]] || rid="r_$(date +%s%N)_$RANDOM"

        rules_listen_ip+=("$listen_ip")
        rules_src_port+=("$src_port")
        rules_dst_port+=("$dst_port")
        rules_resolved_ip+=("$resolved")
        rules_proto+=("$proto")
        rules_id+=("$rid")
        rules_quota_enable+=("$quota_enable")
        rules_quota_bytes+=("$quota_bytes")
    done < "$CONFIG_FILE"
}

remove_all_custom_tables() {
    command -v nft >/dev/null 2>&1 || return 0
    nft delete table ip "$FILTER_TABLE_NAME" >/dev/null 2>&1 || true
    nft delete table ip6 "$FILTER_TABLE_NAME" >/dev/null 2>&1 || true
    nft delete table ip "$TABLE_NAME" >/dev/null 2>&1 || true
    nft delete table ip6 "$TABLE_NAME" >/dev/null 2>&1 || true
}

append_nft_line() {
    NFT_RULE_LINES+=("$1")
}

init_ruleset_base() {
    NFT_RULE_LINES=()
    QUOTA_OBJ_ADDED_IP=()
    QUOTA_OBJ_ADDED_IP6=()

    # --- nat 表（DNAT + masquerade）---
    append_nft_line "add table ip ${TABLE_NAME}"
    append_nft_line "add chain ip ${TABLE_NAME} prerouting { type nat hook prerouting priority dstnat; policy accept; }"
    append_nft_line "add chain ip ${TABLE_NAME} postrouting { type nat hook postrouting priority srcnat; policy accept; }"
    append_nft_line "add chain ip ${TABLE_NAME} ${CHAIN_PRE}"
    append_nft_line "add chain ip ${TABLE_NAME} ${CHAIN_POST}"
    append_nft_line "add rule ip ${TABLE_NAME} prerouting jump ${CHAIN_PRE}"
    append_nft_line "add rule ip ${TABLE_NAME} postrouting jump ${CHAIN_POST}"
    append_nft_line "add rule ip ${TABLE_NAME} ${CHAIN_POST} ct status dnat masquerade"

    append_nft_line "add table ip6 ${TABLE_NAME}"
    append_nft_line "add chain ip6 ${TABLE_NAME} prerouting { type nat hook prerouting priority dstnat; policy accept; }"
    append_nft_line "add chain ip6 ${TABLE_NAME} postrouting { type nat hook postrouting priority srcnat; policy accept; }"
    append_nft_line "add chain ip6 ${TABLE_NAME} ${CHAIN_PRE}"
    append_nft_line "add chain ip6 ${TABLE_NAME} ${CHAIN_POST}"
    append_nft_line "add rule ip6 ${TABLE_NAME} prerouting jump ${CHAIN_PRE}"
    append_nft_line "add rule ip6 ${TABLE_NAME} postrouting jump ${CHAIN_POST}"
    append_nft_line "add rule ip6 ${TABLE_NAME} ${CHAIN_POST} ct status dnat masquerade"

    # --- filter 表（quota 流量统计 + 超额阻断，forward hook 每包执行）---
    append_nft_line "add table ip ${FILTER_TABLE_NAME}"
    append_nft_line "add chain ip ${FILTER_TABLE_NAME} ${FILTER_CHAIN_FWD} { type filter hook forward priority 0; policy accept; }"

    append_nft_line "add table ip6 ${FILTER_TABLE_NAME}"
    append_nft_line "add chain ip6 ${FILTER_TABLE_NAME} ${FILTER_CHAIN_FWD} { type filter hook forward priority 0; policy accept; }"
}

ensure_quota_obj() {
    local family="$1" qname="$2" bytes="$3" used="$4"

    if [[ "$family" == "ip" ]]; then
        [[ -n "${QUOTA_OBJ_ADDED_IP[$qname]}" ]] && return 0
        QUOTA_OBJ_ADDED_IP[$qname]=1
    else
        [[ -n "${QUOTA_OBJ_ADDED_IP6[$qname]}" ]] && return 0
        QUOTA_OBJ_ADDED_IP6[$qname]=1
    fi

    [[ "$bytes" =~ ^[0-9]+$ ]] || bytes=0
    [[ "$used" =~ ^[0-9]+$ ]] || used=0

    # quota 对象放在 filter 表中，forward hook 每包计数
    if [[ "$used" -gt 0 ]]; then
        append_nft_line "add quota ${family} ${FILTER_TABLE_NAME} ${qname} { over ${bytes} bytes ; used ${used} bytes ; }"
    else
        append_nft_line "add quota ${family} ${FILTER_TABLE_NAME} ${qname} { over ${bytes} bytes ; }"
    fi
}

add_single_nft_rule() {
    local family="$1" listen_ip="$2" proto="$3" dport="$4" dnat_target="$5"
    local line="add rule ${family} ${TABLE_NAME} ${CHAIN_PRE} "

    if [[ "$family" == "ip" ]]; then
        [[ "$listen_ip" != "0.0.0.0" ]] && line+="ip daddr ${listen_ip} "
    else
        [[ "$listen_ip" != "::" && "$listen_ip" != "0.0.0.0" ]] && line+="ip6 daddr ${listen_ip} "
    fi

    line+="${proto} dport ${dport} "
    line+="dnat to ${dnat_target}"
    append_nft_line "$line"
}

add_filter_quota_drop_rule() {
    # 在 filter forward 链中：匹配转发到目标IP+端口的流量，超额则 drop
    local family="$1" proto="$2" dst_ip="$3" dst_port="$4" quota_name="$5"
    [[ -z "$quota_name" ]] && return 0

    local addr_kw="ip"
    [[ "$family" == "ip6" ]] && addr_kw="ip6"

    # 超额阻断规则：quota over → drop（quota 对象已在 ensure_quota_obj 中以 "over" 模式创建）
    append_nft_line "add rule ${family} ${FILTER_TABLE_NAME} ${FILTER_CHAIN_FWD} ${addr_kw} daddr ${dst_ip} ${proto} dport ${dst_port} quota over name \"${quota_name}\" drop"
}

add_nft_rule() {
    local listen_ip="$1" src_port="$2" dst_ip="$3" dst_port="$4" proto="$5" rid="$6" q_enable="$7" q_bytes="$8"

    local family="ip" dst_target_ip="$dst_ip"
    if is_valid_ipv6 "$dst_ip"; then
        family="ip6"
        dst_target_ip="[${dst_ip}]"
    fi

    local quota_name=""
    if [[ "$q_enable" == "1" && "$q_bytes" -gt 0 ]]; then
        quota_name=$(quota_name_by_rule_id "$rid")
        ensure_quota_obj "$family" "$quota_name" "$q_bytes" "${QUOTA_USED_MAP[$rid]:-0}"
    fi

    local src_meta dst_meta
    src_meta=$(parse_port_expr "$src_port") || return 1
    dst_meta=$(parse_port_expr "$dst_port") || return 1

    local src_type src_start src_end dst_type dst_start dst_end
    IFS='|' read -r src_type src_start src_end <<< "$src_meta"
    IFS='|' read -r dst_type dst_start dst_end <<< "$dst_meta"

    if [[ "$src_type" == "single" && "$dst_type" == "single" ]] || \
       [[ "$src_type" == "range" && "$dst_type" == "range" && "$src_start" == "$dst_start" && "$src_end" == "$dst_end" ]]; then
        add_single_nft_rule "$family" "$listen_ip" "$proto" "$src_port" "${dst_target_ip}:${dst_port}"
        add_filter_quota_drop_rule "$family" "$proto" "$dst_ip" "$dst_port" "$quota_name"
        return
    fi

    if [[ "$src_type" == "range" && "$dst_type" == "range" ]]; then
        local src_len=$(( src_end - src_start + 1 ))
        [[ "$src_len" -gt 1000 ]] && return 1
        for ((offset=0; offset<src_len; offset++)); do
            add_single_nft_rule "$family" "$listen_ip" "$proto" "$((src_start + offset))" "${dst_target_ip}:$((dst_start + offset))"
            add_filter_quota_drop_rule "$family" "$proto" "$dst_ip" "$((dst_start + offset))" "$quota_name"
        done
        return
    fi

    return 1
}

run_apply() {
    [[ "$(cat /proc/sys/net/ipv4/ip_forward 2>/dev/null)" != "1" ]] && \
        { echo 1 > /proc/sys/net/ipv4/ip_forward 2>/dev/null || return 1; }

    load_rules_for_apply
    load_quota_state_map
    remove_all_custom_tables
    init_ruleset_base

    local fail_count=0
    for ((i=0; i<${#rules_src_port[@]}; i++)); do
        local listen_ip="${rules_listen_ip[$i]}" src_port="${rules_src_port[$i]}"
        local dst_ip="${rules_resolved_ip[$i]}" dst_port="${rules_dst_port[$i]}"
        local proto="${rules_proto[$i]}" rid="${rules_id[$i]}"
        local q_enable="${rules_quota_enable[$i]}" q_bytes="${rules_quota_bytes[$i]}"

        case "$proto" in
            tcp)  add_nft_rule "$listen_ip" "$src_port" "$dst_ip" "$dst_port" "tcp" "$rid" "$q_enable" "$q_bytes" || ((fail_count++)) ;;
            udp)  add_nft_rule "$listen_ip" "$src_port" "$dst_ip" "$dst_port" "udp" "$rid" "$q_enable" "$q_bytes" || ((fail_count++)) ;;
            both)
                add_nft_rule "$listen_ip" "$src_port" "$dst_ip" "$dst_port" "tcp" "$rid" "$q_enable" "$q_bytes" || ((fail_count++))
                add_nft_rule "$listen_ip" "$src_port" "$dst_ip" "$dst_port" "udp" "$rid" "$q_enable" "$q_bytes" || ((fail_count++))
                ;;
        esac
    done

    local nft_tmp
    nft_tmp=$(mktemp)
    printf "%s\n" "${NFT_RULE_LINES[@]}" > "$nft_tmp"

    local nft_out nft_rc=0
    nft_out=$(nft -f "$nft_tmp" 2>&1) || nft_rc=$?
    rm -f "$nft_tmp"

    if [[ "$nft_rc" -ne 0 ]]; then
        echo "[错误] nft 应用失败: ${nft_out}" >&2
        return 1
    fi
    [[ "$fail_count" -gt 0 ]] && echo "[警告] 共 ${fail_count} 条规则构建失败（已跳过）" >&2
    return 0
}

get_quota_used_bytes() {
    local family="$1" qname="$2"
    local out used
    # quota 对象现在位于 filter 表
    out=$(nft list quota "$family" "$FILTER_TABLE_NAME" "$qname" 2>/dev/null || true)
    used=$(echo "$out" | grep -oE 'used[[:space:]]+[0-9]+[[:space:]]+bytes' | head -n1 | grep -oE '[0-9]+' | head -n1)
    [[ "$used" =~ ^[0-9]+$ ]] || used=0
    echo "$used"
}

run_save_quota_state() {
    mkdir -p "$CONFIG_DIR"
    load_rules_for_apply

    local tmp_file now
    tmp_file="${QUOTA_STATE_FILE}.tmp.$$"
    now=$(date +%s)
    : > "$tmp_file"

    local i rid q_enable q_bytes qname family used
    declare -A seen
    for ((i=0; i<${#rules_id[@]}; i++)); do
        rid="${rules_id[$i]}"
        q_enable="${rules_quota_enable[$i]}"
        q_bytes="${rules_quota_bytes[$i]}"
        [[ "$q_enable" == "1" && "$q_bytes" -gt 0 ]] || continue

        qname=$(quota_name_by_rule_id "$rid")
        [[ -n "${seen[$rid]}" ]] && continue
        seen[$rid]=1

        if is_valid_ipv6 "${rules_resolved_ip[$i]}"; then family="ip6"; else family="ip"; fi
        used=$(get_quota_used_bytes "$family" "$qname")
        echo "${rid}|${qname}|${used}|${now}" >> "$tmp_file"
    done

    mv -f "$tmp_file" "$QUOTA_STATE_FILE"
}

rewrite_quota_state_with_keep_and_resets() {
    local keep_csv="$1" reset_csv="$2"
    local tmp_file="${QUOTA_STATE_FILE}.tmp.$$"
    local now
    now=$(date +%s)

    : > "$tmp_file"
    if [[ -f "$QUOTA_STATE_FILE" ]]; then
        local rid qname used ts
        while IFS='|' read -r rid qname used ts; do
            [[ -z "$rid" || "$rid" == \#* ]] && continue
            [[ ",$keep_csv," == *",$rid,"* ]] || continue
            [[ "$used" =~ ^[0-9]+$ ]] || used=0
            if [[ ",$reset_csv," == *",$rid,"* ]]; then
                used=0
                ts="$now"
            fi
            [[ -n "$qname" ]] || qname=$(quota_name_by_rule_id "$rid")
            echo "${rid}|${qname}|${used}|${ts}" >> "$tmp_file"
        done < "$QUOTA_STATE_FILE"
    fi

    mv -f "$tmp_file" "$QUOTA_STATE_FILE"
}

run_maintain() {
    [[ -f "$CONFIG_FILE" ]] || return 0

    exec 201>"$LOCK_FILE"
    flock -n 201 || return 0

    local tmp_file raw_line now changed
    tmp_file=$(mktemp)
    now=$(date +%s)
    changed=0

    local keep_ids=()
    local reset_ids=()

    while IFS= read -r raw_line; do
        IFS='|' read -r c1 c2 c3 c4 c5 c6 c7 c8 c9 c10 c11 c12 c13 c14 c15 c16 c17 <<< "$raw_line"

        if [[ -z "$c1" || "$c1" == \#* || "$c1" =~ ^GLOBAL_ ]]; then
            printf '%s\n' "$raw_line" >> "$tmp_file"
            continue
        fi

        local listen_ip="$c1" src_port="$c2" dst_host="$c3" dst_port="$c4" proto="$c5"
        local resolved_ip="$c6" check_interval="$c7" last_check_ts="$c8" is_domain="$c9"
        local rid="$c10" q_enable="$c11" q_bytes="$c12" expire_days="$c13" expire_ts="$c14" reset_days="$c15" last_reset_ts="$c16" created_ts="$c17"

        [[ -n "$created_ts" ]] || created_ts="$now"
        [[ -n "$rid" ]] || rid="r_$(date +%s%N)_$RANDOM"
        [[ "$q_enable" == "1" ]] || q_enable=0
        [[ "$q_bytes" =~ ^[0-9]+$ ]] || q_bytes=0
        [[ "$expire_days" =~ ^[0-9]+$ ]] || expire_days=0
        [[ "$expire_ts" =~ ^[0-9]+$ ]] || expire_ts=0
        [[ "$reset_days" =~ ^[0-9]+$ ]] || reset_days=30
        [[ "$last_reset_ts" =~ ^[0-9]+$ ]] || last_reset_ts=0

        if [[ "$q_enable" == "1" && "$expire_ts" -gt 0 && "$now" -ge "$expire_ts" ]]; then
            changed=1
            continue
        fi

        if [[ "$q_enable" == "1" && "$reset_days" -gt 0 ]]; then
            local need_reset=0
            if [[ "$last_reset_ts" -le 0 ]]; then
                need_reset=1
            elif (( now - last_reset_ts >= reset_days * 86400 )); then
                need_reset=1
            fi

            if [[ "$need_reset" -eq 1 ]]; then
                last_reset_ts="$now"
                reset_ids+=("$rid")
                changed=1
            fi
        fi

        keep_ids+=("$rid")
        echo "${listen_ip}|${src_port}|${dst_host}|${dst_port}|${proto}|${resolved_ip}|${check_interval}|${last_check_ts}|${is_domain}|${rid}|${q_enable}|${q_bytes}|${expire_days}|${expire_ts}|${reset_days}|${last_reset_ts}|${created_ts}" >> "$tmp_file"
    done < "$CONFIG_FILE"

    if [[ "$changed" -eq 1 ]] || ! cmp -s "$tmp_file" "$CONFIG_FILE"; then
        mv -f "$tmp_file" "$CONFIG_FILE"
    else
        rm -f "$tmp_file"
    fi

    local keep_csv reset_csv
    keep_csv=$(IFS=','; echo "${keep_ids[*]}")
    reset_csv=$(IFS=','; echo "${reset_ids[*]}")
    rewrite_quota_state_with_keep_and_resets "$keep_csv" "$reset_csv"

    if [[ "$changed" -eq 1 ]]; then
        local apply_cmd="$SCRIPT_SELF"
        [[ -x "$apply_cmd" ]] || apply_cmd="/usr/local/bin/nftables-forward"
        "$apply_cmd" --apply >/dev/null 2>&1 || true
    fi

    exec 201>&-
}

run_watch() {
    [[ -f "$CONFIG_FILE" ]] || return 0
    read_global_watch_enabled
    [[ "$GLOBAL_WATCH_ENABLED" == "1" ]] || return 0
    [[ -t 1 ]] && MANUAL_MODE=1

    exec 200>"$LOCK_FILE"
    flock -n 200 || return 0

    local tmp_file now changed raw_line
    tmp_file=$(mktemp)
    now=$(date +%s)
    changed=0

    while IFS= read -r raw_line; do
        IFS='|' read -r c1 c2 c3 c4 c5 c6 c7 c8 c9 c10 c11 c12 c13 c14 c15 c16 c17 <<< "$raw_line"

        if [[ -z "$c1" || "$c1" == \#* || "$c1" =~ ^GLOBAL_ ]]; then
            printf '%s\n' "$raw_line" >> "$tmp_file"
            continue
        fi

        local listen_ip="$c1" src_port="$c2" dst_host="$c3" dst_port="$c4" proto="$c5"
        local resolved_ip="$c6" check_interval="$c7" last_check_ts="$c8" is_domain="$c9"
        local rid="$c10" q_enable="$c11" q_bytes="$c12" expire_days="$c13" expire_ts="$c14" reset_days="$c15" last_reset_ts="$c16" created_ts="$c17"

        [[ "$check_interval" =~ ^[0-9]+$ ]] || check_interval=0
        [[ "$last_check_ts" =~ ^[0-9]+$ ]] || last_check_ts=0
        [[ -n "$rid" ]] || rid="r_$(date +%s%N)_$RANDOM"
        [[ "$q_enable" == "1" ]] || q_enable=0
        [[ "$q_bytes" =~ ^[0-9]+$ ]] || q_bytes=0
        [[ "$expire_days" =~ ^[0-9]+$ ]] || expire_days=0
        [[ "$expire_ts" =~ ^[0-9]+$ ]] || expire_ts=0
        [[ "$reset_days" =~ ^[0-9]+$ ]] || reset_days=30
        [[ "$last_reset_ts" =~ ^[0-9]+$ ]] || last_reset_ts=0
        [[ "$created_ts" =~ ^[0-9]+$ ]] || created_ts="$now"

        if [[ "$is_domain" == "1" ]]; then
            [[ "$check_interval" -le 0 ]] && check_interval=300
            local need_check=0
            [[ "$MANUAL_MODE" -eq 1 ]] && need_check=1
            (( now - last_check_ts >= check_interval )) && need_check=1

            if [[ "$need_check" -eq 1 ]]; then
                local new_ip
                new_ip=$(resolve_domain_ip "$dst_host" 2>/dev/null || true)
                if is_valid_ip "$new_ip"; then
                    [[ "$MANUAL_MODE" -eq 1 ]] && echo "${dst_host} -> ${new_ip}"
                    if [[ "$new_ip" != "$resolved_ip" ]]; then
                        change_records+=("${dst_host}: ${resolved_ip} -> ${new_ip}")
                        resolved_ip="$new_ip"
                        changed=1
                    fi
                    last_check_ts="$now"
                fi
            fi
        fi

        echo "${listen_ip}|${src_port}|${dst_host}|${dst_port}|${proto}|${resolved_ip}|${check_interval}|${last_check_ts}|${is_domain}|${rid}|${q_enable}|${q_bytes}|${expire_days}|${expire_ts}|${reset_days}|${last_reset_ts}|${created_ts}" >> "$tmp_file"
    done < "$CONFIG_FILE"

    if [[ "$changed" -eq 1 ]]; then
        mv -f "$tmp_file" "$CONFIG_FILE"
        if [[ "$MANUAL_MODE" -eq 0 ]]; then
            sleep 1
            local apply_cmd="$SCRIPT_SELF"
            [[ -x "$apply_cmd" ]] || apply_cmd="/usr/local/bin/nftables-forward"

            local apply_output apply_rc=0
            apply_output=$("$apply_cmd" --apply 2>&1) || apply_rc=$?
            if [[ "$apply_rc" -ne 0 ]]; then
                local one_line
                one_line=$(echo "$apply_output" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g' | cut -c1-500)
                log_watch "apply failed rc=${apply_rc} uid=${EUID} cmd='${apply_cmd} --apply' err='${one_line}'"
            fi

            local record
            for record in "${change_records[@]}"; do
                log_watch "IP changed: ${record}"
            done
        fi
    elif ! cmp -s "$tmp_file" "$CONFIG_FILE"; then
        mv -f "$tmp_file" "$CONFIG_FILE"
    else
        rm -f "$tmp_file"
    fi

    exec 200>&-
}

main() {
    local mode="apply"
    case "${1:-}" in
        --watch) mode="watch" ;;
        --save-quota-state) mode="save_quota" ;;
        --maintain) mode="maintain" ;;
        --apply|"") mode="apply" ;;
        *) mode="apply" ;;
    esac

    if [[ "$EUID" -ne 0 ]]; then
        log_watch "insufficient privileges: uid=${EUID}, mode=${mode}"
        echo "[错误] 请使用 root 权限运行（uid=${EUID}, mode=${mode}）" >&2
        return 1
    fi

    if ! command -v nft >/dev/null 2>&1; then
        log_watch "nft command not found, mode=${mode}, PATH=${PATH}"
        echo "[错误] nft 未找到，请确认已安装并可在当前 PATH 下执行" >&2
        return 1
    fi

    mkdir -p "$CONFIG_DIR"

    case "$mode" in
        watch) run_watch ;;
        save_quota) run_save_quota_state ;;
        maintain) run_maintain ;;
        apply) run_apply ;;
    esac
}

main "$@"
