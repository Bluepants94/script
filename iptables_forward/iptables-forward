#!/bin/bash

# ============================================================
#  iptables 端口转发统一脚本（apply + watch）
#  --apply : 读取 rules.conf 并重建 iptables 规则
#  --watch : 解析域名并按需触发规则重建
# ============================================================

export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH}"

CONFIG_DIR="/etc/iptables-forward"
CONFIG_FILE="${CONFIG_DIR}/rules.conf"
LOCK_FILE="${CONFIG_DIR}/rules.conf.lock"
CHAIN_PRE="IPTFWD-PRE"
CHAIN_POST="IPTFWD-POST"
SCRIPT_SELF="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || true)"

GLOBAL_WATCH_ENABLED=1
IP6_CHAINS_READY=0
MANUAL_MODE=0
change_records=()

log_watch() {
    command -v logger >/dev/null 2>&1 && logger -t iptables-forward "$1"
}

write_config_line() {
    local c1="${1:-}" c2="${2:-}" c3="${3:-}" c4="${4:-}" c5="${5:-}" c6="${6:-}" c7="${7:-}" c8="${8:-}" c9="${9:-}"
    echo "$c1${c2:+|$c2}${c3:+|$c3}${c4:+|$c4}${c5:+|$c5}${c6:+|$c6}${c7:+|$c7}${c8:+|$c8}${c9:+|$c9}"
}

is_valid_ipv4() {
    local ip="$1"
    [[ "$ip" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]] || return 1
    IFS='.' read -r o1 o2 o3 o4 <<< "$ip"
    for o in "$o1" "$o2" "$o3" "$o4"; do
        [[ "$o" -ge 0 && "$o" -le 255 ]] || return 1
    done
    return 0
}

is_valid_ipv6() {
    local ip="$1"
    [[ "$ip" == *:* ]] || return 1
    [[ "$ip" =~ ^[0-9A-Fa-f:]+$ ]] || return 1
    return 0
}

is_valid_ip() {
    is_valid_ipv4 "$1" || is_valid_ipv6 "$1"
}

read_global_watch_enabled() {
    [[ -f "$CONFIG_FILE" ]] || return 0
    local enabled
    enabled=$(grep -m1 '^GLOBAL_WATCH_ENABLED=' "$CONFIG_FILE" 2>/dev/null | cut -d'=' -f2)
    if [[ "$enabled" == "0" || "$enabled" == "1" ]]; then
        GLOBAL_WATCH_ENABLED="$enabled"
    fi
}

resolve_domain_ip() {
    local domain="$1"
    local ip=""

    if command -v dig >/dev/null 2>&1; then
        ip=$(dig @8.8.8.8 "$domain" +short 2>/dev/null | grep -oE '^([0-9]{1,3}\.){3}[0-9]{1,3}$' | head -n 1)
        is_valid_ipv4 "$ip" && { echo "$ip"; return 0; }

        ip=$(dig @8.8.8.8 AAAA "$domain" +short 2>/dev/null | grep -oE '^[0-9A-Fa-f:]+$' | head -n 1)
        is_valid_ipv6 "$ip" && { echo "$ip"; return 0; }

        ip=$(dig @1.1.1.1 "$domain" +short 2>/dev/null | grep -oE '^([0-9]{1,3}\.){3}[0-9]{1,3}$' | head -n 1)
        is_valid_ipv4 "$ip" && { echo "$ip"; return 0; }

        ip=$(dig @1.1.1.1 AAAA "$domain" +short 2>/dev/null | grep -oE '^[0-9A-Fa-f:]+$' | head -n 1)
        is_valid_ipv6 "$ip" && { echo "$ip"; return 0; }
    fi

    return 1
}

to_iptables_dport() {
    echo "$1" | sed 's/-/:/'
}

parse_port_expr() {
    local expr="$1"
    if [[ "$expr" =~ ^[0-9]+$ ]]; then
        if [[ "$expr" -ge 1 && "$expr" -le 65535 ]]; then
            echo "single|$expr|$expr"
            return 0
        fi
        return 1
    fi
    if [[ "$expr" =~ ^([0-9]+)-([0-9]+)$ ]]; then
        local a="${BASH_REMATCH[1]}"
        local b="${BASH_REMATCH[2]}"
        if [[ "$a" -ge 1 && "$b" -le 65535 && "$a" -lt "$b" ]]; then
            echo "range|$a|$b"
            return 0
        fi
        return 1
    fi
    return 1
}

ensure_ip6_chains() {
    [[ "$IP6_CHAINS_READY" -eq 1 ]] && return 0
    command -v ip6tables >/dev/null 2>&1 || return 1

    ip6tables -t nat -N "$CHAIN_PRE" 2>/dev/null || ip6tables -t nat -F "$CHAIN_PRE"
    ip6tables -t nat -N "$CHAIN_POST" 2>/dev/null || ip6tables -t nat -F "$CHAIN_POST"
    ip6tables -t nat -C PREROUTING -j "$CHAIN_PRE" 2>/dev/null || ip6tables -t nat -A PREROUTING -j "$CHAIN_PRE"
    ip6tables -t nat -C POSTROUTING -j "$CHAIN_POST" 2>/dev/null || ip6tables -t nat -A POSTROUTING -j "$CHAIN_POST"

    IP6_CHAINS_READY=1
    return 0
}

rules_listen_ip=()
rules_src_port=()
rules_dst_port=()
rules_resolved_ip=()
rules_proto=()

load_rules_for_apply() {
    [[ -f "$CONFIG_FILE" ]] || return 1

    rules_listen_ip=()
    rules_src_port=()
    rules_dst_port=()
    rules_resolved_ip=()
    rules_proto=()

    while IFS='|' read -r c1 c2 c3 c4 c5 c6 c7 c8 c9; do
        [[ -z "$c1" || "$c1" == \#* ]] && continue
        [[ "$c1" =~ ^GLOBAL_WATCH_ENABLED= ]] && continue
        [[ "$c1" =~ ^GLOBAL_WATCH_INTERVAL_MINUTES= ]] && continue
        [[ "$c1" =~ ^GLOBAL_RESTART_INTERVAL_MINUTES= ]] && continue

        if [[ -n "$c9" ]]; then
            local resolved="$c6"
            is_valid_ip "$resolved" || resolved="$c3"
            is_valid_ip "$resolved" || continue

            rules_listen_ip+=("$c1")
            rules_src_port+=("$c2")
            rules_dst_port+=("$c4")
            rules_resolved_ip+=("$resolved")
            rules_proto+=("$c5")
        elif [[ -n "$c5" ]]; then
            is_valid_ip "$c3" || continue

            rules_listen_ip+=("$c1")
            rules_src_port+=("$c2")
            rules_dst_port+=("$c4")
            rules_resolved_ip+=("$c3")
            rules_proto+=("$c5")
        elif [[ -n "$c4" ]]; then
            is_valid_ipv4 "$c2" || continue

            rules_listen_ip+=("0.0.0.0")
            rules_src_port+=("$c1")
            rules_dst_port+=("$c3")
            rules_resolved_ip+=("$c2")
            rules_proto+=("$c4")
        fi
    done < "$CONFIG_FILE"
}

init_custom_chains() {
    iptables -t nat -N "$CHAIN_PRE" 2>/dev/null || iptables -t nat -F "$CHAIN_PRE"
    iptables -t nat -N "$CHAIN_POST" 2>/dev/null || iptables -t nat -F "$CHAIN_POST"

    iptables -t nat -C PREROUTING -j "$CHAIN_PRE" 2>/dev/null || iptables -t nat -A PREROUTING -j "$CHAIN_PRE"
    iptables -t nat -C POSTROUTING -j "$CHAIN_POST" 2>/dev/null || iptables -t nat -A POSTROUTING -j "$CHAIN_POST"
}

add_masquerade_rules() {
    iptables -t nat -A "$CHAIN_POST" -m conntrack --ctstate DNAT -j MASQUERADE || return 1
    if [[ "$IP6_CHAINS_READY" -eq 1 ]]; then
        ip6tables -t nat -A "$CHAIN_POST" -m conntrack --ctstate DNAT -j MASQUERADE 2>/dev/null || return 1
    fi
    return 0
}

add_iptables_rule() {
    local listen_ip="$1"
    local src_port="$2"
    local dst_ip="$3"
    local dst_port="$4"
    local proto="$5"

    local ip_cmd="iptables"
    local dst_target_ip="$dst_ip"
    if is_valid_ipv6 "$dst_ip"; then
        ensure_ip6_chains || return 1
        ip_cmd="ip6tables"
        dst_target_ip="[$dst_ip]"
    fi

    local src_dport dst_dport
    src_dport=$(to_iptables_dport "$src_port")
    dst_dport=$(to_iptables_dport "$dst_port")

    local src_meta dst_meta
    src_meta=$(parse_port_expr "$src_port") || return 1
    dst_meta=$(parse_port_expr "$dst_port") || return 1

    local src_type src_start src_end dst_type dst_start dst_end
    IFS='|' read -r src_type src_start src_end <<< "$src_meta"
    IFS='|' read -r dst_type dst_start dst_end <<< "$dst_meta"

    local dnat_target
    if [[ "$src_type" == "single" && "$dst_type" == "single" ]]; then
        dnat_target="${dst_target_ip}:${dst_dport}"
    elif [[ "$src_type" == "range" && "$dst_type" == "range" ]]; then
        if [[ "$src_start" == "$dst_start" && "$src_end" == "$dst_end" ]]; then
            dnat_target="${dst_target_ip}:${dst_dport}"
        else
            local src_len=$(( src_end - src_start + 1 ))
            if [[ "$src_len" -gt 1000 ]]; then
                echo "[警告] 端口段过大 (${src_len} 端口)，跳过此规则" >&2
                return 1
            fi
            for ((offset=0; offset<src_len; offset++)); do
                local sp=$((src_start + offset))
                local dp=$((dst_start + offset))

                if [[ "$listen_ip" == "0.0.0.0" || ( "$listen_ip" == "::" && "$ip_cmd" == "ip6tables" ) ]]; then
                    "$ip_cmd" -t nat -A "$CHAIN_PRE" -p "$proto" --dport "$sp" -j DNAT --to-destination "${dst_target_ip}:${dp}" || \
                        echo "[错误] 添加规则失败: ${listen_ip} ${sp} -> ${dst_target_ip}:${dp} (${proto})" >&2
                else
                    "$ip_cmd" -t nat -A "$CHAIN_PRE" -d "$listen_ip" -p "$proto" --dport "$sp" -j DNAT --to-destination "${dst_target_ip}:${dp}" || \
                        echo "[错误] 添加规则失败: ${listen_ip} ${sp} -> ${dst_target_ip}:${dp} (${proto})" >&2
                fi
            done
            return 0
        fi
    else
        return 1
    fi

    if [[ "$listen_ip" == "0.0.0.0" || ( "$listen_ip" == "::" && "$ip_cmd" == "ip6tables" ) ]]; then
        "$ip_cmd" -t nat -A "$CHAIN_PRE" -p "$proto" --dport "$src_dport" -j DNAT --to-destination "$dnat_target" || \
            echo "[错误] 添加规则失败: ${listen_ip} ${src_dport} -> ${dnat_target} (${proto})" >&2
    else
        "$ip_cmd" -t nat -A "$CHAIN_PRE" -d "$listen_ip" -p "$proto" --dport "$src_dport" -j DNAT --to-destination "$dnat_target" || \
            echo "[错误] 添加规则失败: ${listen_ip} ${src_dport} -> ${dnat_target} (${proto})" >&2
    fi
}

run_apply() {
    if [[ "$(cat /proc/sys/net/ipv4/ip_forward 2>/dev/null)" != "1" ]]; then
        echo 1 > /proc/sys/net/ipv4/ip_forward 2>/dev/null || return 1
    fi

    load_rules_for_apply
    init_custom_chains || return 1

    if [[ ${#rules_src_port[@]} -eq 0 ]]; then
        add_masquerade_rules
        return $?
    fi

    local fail_count=0
    for ((i=0; i<${#rules_src_port[@]}; i++)); do
        local listen_ip="${rules_listen_ip[$i]}"
        local src_port="${rules_src_port[$i]}"
        local dst_ip="${rules_resolved_ip[$i]}"
        local dst_port="${rules_dst_port[$i]}"
        local proto="${rules_proto[$i]}"

        case "$proto" in
            tcp)
                add_iptables_rule "$listen_ip" "$src_port" "$dst_ip" "$dst_port" "tcp" || ((fail_count++))
                ;;
            udp)
                add_iptables_rule "$listen_ip" "$src_port" "$dst_ip" "$dst_port" "udp" || ((fail_count++))
                ;;
            both)
                add_iptables_rule "$listen_ip" "$src_port" "$dst_ip" "$dst_port" "tcp" || ((fail_count++))
                add_iptables_rule "$listen_ip" "$src_port" "$dst_ip" "$dst_port" "udp" || ((fail_count++))
                ;;
        esac
    done

    add_masquerade_rules || return 1

    if [[ "$fail_count" -gt 0 ]]; then
        echo "[警告] 共 ${fail_count} 条规则应用失败" >&2
        return 1
    fi
    return 0
}

run_watch() {
    [[ -f "$CONFIG_FILE" ]] || return 0
    read_global_watch_enabled
    [[ "$GLOBAL_WATCH_ENABLED" == "1" ]] || return 0
    [[ -t 1 ]] && MANUAL_MODE=1

    exec 200>"$LOCK_FILE"
    if ! flock -n 200; then
        return 0
    fi

    local tmp_file now changed
    tmp_file=$(mktemp)
    now=$(date +%s)
    changed=0

    while IFS='|' read -r c1 c2 c3 c4 c5 c6 c7 c8 c9; do
        if [[ -z "$c1" || "$c1" == \#* ]]; then
            write_config_line "$c1" "$c2" "$c3" "$c4" "$c5" "$c6" "$c7" "$c8" "$c9" >> "$tmp_file"
            continue
        fi

        if [[ "$c1" =~ ^GLOBAL_WATCH_ENABLED= ]] || [[ "$c1" =~ ^GLOBAL_WATCH_INTERVAL_MINUTES= ]] || [[ "$c1" =~ ^GLOBAL_RESTART_INTERVAL_MINUTES= ]]; then
            write_config_line "$c1" "$c2" "$c3" "$c4" "$c5" "$c6" "$c7" "$c8" "$c9" >> "$tmp_file"
            continue
        fi

        local listen_ip="$c1" src_port="$c2" dst_host="$c3" dst_port="$c4" proto="$c5"
        local resolved_ip="$c6" check_interval="$c7" last_check_ts="$c8" is_domain="$c9"

        [[ "$check_interval" =~ ^[0-9]+$ ]] || check_interval=0
        [[ "$last_check_ts" =~ ^[0-9]+$ ]] || last_check_ts=0

        if [[ "$is_domain" == "1" ]]; then
            [[ "$check_interval" -le 0 ]] && check_interval=300
            local need_check=0
            if [[ "$MANUAL_MODE" -eq 1 ]]; then
                need_check=1
            elif (( now - last_check_ts >= check_interval )); then
                need_check=1
            fi

            if [[ "$need_check" -eq 1 ]]; then
                local new_ip
                new_ip=$(resolve_domain_ip "$dst_host" 2>/dev/null || true)
                if is_valid_ip "$new_ip"; then
                    [[ "$MANUAL_MODE" -eq 1 ]] && echo "${dst_host} -> ${new_ip}"
                    if [[ "$new_ip" != "$resolved_ip" ]]; then
                        local old_ip="$resolved_ip"
                        resolved_ip="$new_ip"
                        changed=1
                        change_records+=("${dst_host}: ${old_ip} -> ${new_ip}")
                    fi
                    last_check_ts="$now"
                fi
            fi
        fi

        echo "${listen_ip}|${src_port}|${dst_host}|${dst_port}|${proto}|${resolved_ip}|${check_interval}|${last_check_ts}|${is_domain}" >> "$tmp_file"
    done < "$CONFIG_FILE"

    if [[ "$changed" -eq 1 ]]; then
        cp "$tmp_file" "$CONFIG_FILE"
        if [[ "$MANUAL_MODE" -eq 0 ]]; then
            sleep 3
            local apply_cmd="$SCRIPT_SELF"
            [[ -x "$apply_cmd" ]] || apply_cmd="/usr/local/bin/iptables-forward"

            local apply_output=""
            local apply_rc=0
            apply_output=$("$apply_cmd" --apply 2>&1)
            apply_rc=$?
            if [[ "$apply_rc" -ne 0 ]]; then
                local apply_output_one_line
                apply_output_one_line=$(echo "$apply_output" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g' | cut -c1-500)
                log_watch "apply failed rc=${apply_rc} uid=${EUID} cmd='${apply_cmd} --apply' err='${apply_output_one_line}'"
            fi
        fi

        if [[ "$MANUAL_MODE" -eq 0 ]]; then
            local record
            for record in "${change_records[@]}"; do
                log_watch "IP changed: ${record}"
            done
        fi
    elif ! cmp -s "$tmp_file" "$CONFIG_FILE"; then
        cp "$tmp_file" "$CONFIG_FILE"
    fi

    rm -f "$tmp_file"
    return 0
}

main() {
    local mode="apply"
    case "${1:-}" in
        --watch) mode="watch" ;;
        --apply|"") mode="apply" ;;
        *) mode="apply" ;;
    esac

    if [[ "$EUID" -ne 0 ]]; then
        log_watch "insufficient privileges: uid=${EUID}, mode=${mode}"
        echo "[错误] 请使用 root 权限运行（uid=${EUID}, mode=${mode}）" >&2
        return 1
    fi

    if ! command -v iptables >/dev/null 2>&1; then
        log_watch "iptables command not found, mode=${mode}, PATH=${PATH}"
        echo "[错误] iptables 未找到，请确认已安装并可在当前 PATH 下执行" >&2
        return 1
    fi

    if [[ "$mode" == "watch" ]]; then
        run_watch
    else
        run_apply
    fi
}

main "$@"
