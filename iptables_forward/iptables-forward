#!/bin/bash

# ============================================================
#  nftables 端口转发统一脚本（apply + watch）
#  --apply : 读取 rules.conf 并重建 nftables 规则
#  --watch : 解析域名并按需触发规则重建
# ============================================================

export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH}"

CONFIG_DIR="/etc/nftables-forward"
CONFIG_FILE="${CONFIG_DIR}/rules.conf"
LOCK_FILE="${CONFIG_DIR}/rules.conf.lock"
CHAIN_PRE="IPTFWD-PRE"
CHAIN_POST="IPTFWD-POST"
NFT_TABLE="iptfwd"
SCRIPT_SELF="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || true)"

GLOBAL_WATCH_ENABLED=1
MANUAL_MODE=0
change_records=()

log_watch() {
    command -v logger >/dev/null 2>&1 && logger -t nftables-forward "$1"
}

is_valid_ipv4() {
    local ip="$1"
    [[ "$ip" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]] || return 1
    IFS='.' read -r o1 o2 o3 o4 <<< "$ip"
    for o in "$o1" "$o2" "$o3" "$o4"; do
        [[ "$o" -ge 0 && "$o" -le 255 ]] || return 1
    done
    return 0
}

is_valid_ipv6() {
    [[ "$1" == *:* && "$1" =~ ^[0-9A-Fa-f:]+$ ]]
}

is_valid_ip() {
    is_valid_ipv4 "$1" || is_valid_ipv6 "$1"
}

read_global_watch_enabled() {
    [[ -f "$CONFIG_FILE" ]] || return 0
    local enabled
    enabled=$(grep -m1 '^GLOBAL_WATCH_ENABLED=' "$CONFIG_FILE" 2>/dev/null | cut -d'=' -f2)
    [[ "$enabled" == "0" || "$enabled" == "1" ]] && GLOBAL_WATCH_ENABLED="$enabled"
}

resolve_domain_ip() {
    local domain="$1" ip=""
    command -v dig >/dev/null 2>&1 || return 1

    local server type
    for server in 8.8.8.8 1.1.1.1; do
        for type in A AAAA; do
            ip=$(dig @"$server" "$type" "$domain" +short 2>/dev/null | head -n 1)
            if [[ "$type" == "A" ]]; then
                is_valid_ipv4 "$ip" && { echo "$ip"; return 0; }
            else
                is_valid_ipv6 "$ip" && { echo "$ip"; return 0; }
            fi
        done
    done
    return 1
}

parse_port_expr() {
    local expr="$1"
    if [[ "$expr" =~ ^[0-9]+$ ]]; then
        [[ "$expr" -ge 1 && "$expr" -le 65535 ]] && { echo "single|$expr|$expr"; return 0; }
        return 1
    fi
    if [[ "$expr" =~ ^([0-9]+)-([0-9]+)$ ]]; then
        local a="${BASH_REMATCH[1]}" b="${BASH_REMATCH[2]}"
        [[ "$a" -ge 1 && "$b" -le 65535 && "$a" -lt "$b" ]] && { echo "range|$a|$b"; return 0; }
        return 1
    fi
    return 1
}

# ---------- apply 用规则数组 ----------
rules_listen_ip=()
rules_src_port=()
rules_dst_port=()
rules_resolved_ip=()
rules_proto=()

load_rules_for_apply() {
    [[ -f "$CONFIG_FILE" ]] || return 1

    rules_listen_ip=(); rules_src_port=(); rules_dst_port=()
    rules_resolved_ip=(); rules_proto=()

    while IFS='|' read -r c1 c2 c3 c4 c5 c6 c7 c8 c9; do
        [[ -z "$c1" || "$c1" == \#* || "$c1" =~ ^GLOBAL_ ]] && continue

        local listen_ip src_port dst_port resolved proto

        if [[ -n "$c9" ]]; then
            listen_ip="$c1"; src_port="$c2"; dst_port="$c4"; proto="$c5"
            resolved="$c6"; is_valid_ip "$resolved" || resolved="$c3"
        elif [[ -n "$c5" ]]; then
            listen_ip="$c1"; src_port="$c2"; dst_port="$c4"; proto="$c5"; resolved="$c3"
        elif [[ -n "$c4" ]]; then
            listen_ip="0.0.0.0"; src_port="$c1"; dst_port="$c3"; proto="$c4"; resolved="$c2"
        else
            continue
        fi

        is_valid_ip "$resolved" || continue
        rules_listen_ip+=("$listen_ip"); rules_src_port+=("$src_port")
        rules_dst_port+=("$dst_port"); rules_resolved_ip+=("$resolved"); rules_proto+=("$proto")
    done < "$CONFIG_FILE"
}

setup_nft_family() {
    local family="$1"
    nft add table "$family" "$NFT_TABLE" >/dev/null 2>&1 || true
    nft flush table "$family" "$NFT_TABLE" >/dev/null 2>&1 || return 1
    nft add chain "$family" "$NFT_TABLE" prerouting '{ type nat hook prerouting priority dstnat; policy accept; }' >/dev/null 2>&1 || return 1
    nft add chain "$family" "$NFT_TABLE" postrouting '{ type nat hook postrouting priority srcnat; policy accept; }' >/dev/null 2>&1 || return 1
}

cleanup_unused_ip6_table() {
    nft delete table ip6 "$NFT_TABLE" >/dev/null 2>&1 || true
}

add_single_nft_rule() {
    local family="$1" listen_ip="$2" proto="$3" src_dport="$4" dst_ip="$5" dst_port="$6"
    local dnat_target="$dst_ip:$dst_port"
    local -a cmd=(add rule "$family" "$NFT_TABLE" prerouting)

    if [[ "$family" == "ip" ]]; then
        if is_valid_ipv4 "$listen_ip" && [[ "$listen_ip" != "0.0.0.0" ]]; then
            cmd+=(ip daddr "$listen_ip")
        fi
    else
        dnat_target="[$dst_ip]:$dst_port"
        if is_valid_ipv6 "$listen_ip" && [[ "$listen_ip" != "::" ]]; then
            cmd+=(ip6 daddr "$listen_ip")
        fi
    fi

    cmd+=("$proto" dport "$src_dport" dnat to "$dnat_target")
    nft "${cmd[@]}" >/dev/null 2>&1 || {
        echo "[错误] 添加规则失败: ${listen_ip} ${src_dport} -> ${dnat_target} (${proto}, ${family})" >&2
        return 1
    }
}

add_nft_rule() {
    local listen_ip="$1" src_port="$2" dst_ip="$3" dst_port="$4" proto="$5"
    local family="ip"
    is_valid_ipv6 "$dst_ip" && family="ip6"

    local src_meta dst_meta
    src_meta=$(parse_port_expr "$src_port") || return 1
    dst_meta=$(parse_port_expr "$dst_port") || return 1

    local src_type src_start src_end dst_type dst_start dst_end
    IFS='|' read -r src_type src_start src_end <<< "$src_meta"
    IFS='|' read -r dst_type dst_start dst_end <<< "$dst_meta"

    if [[ "$src_type" == "single" && "$dst_type" == "single" ]]; then
        add_single_nft_rule "$family" "$listen_ip" "$proto" "$src_start" "$dst_ip" "$dst_start"
        return $?
    fi

    if [[ "$src_type" == "range" && "$dst_type" == "range" ]]; then
        local src_len=$(( src_end - src_start + 1 ))
        local dst_len=$(( dst_end - dst_start + 1 ))
        if [[ "$src_len" -ne "$dst_len" ]]; then
            return 1
        fi
        if [[ "$src_len" -gt 1000 ]]; then
            echo "[警告] 端口段过大 (${src_len} 端口)，跳过此规则" >&2
            return 1
        fi
        local offset
        for ((offset=0; offset<src_len; offset++)); do
            add_single_nft_rule "$family" "$listen_ip" "$proto" "$((src_start + offset))" "$dst_ip" "$((dst_start + offset))" || return 1
        done
        return 0
    fi

    return 1
}

add_masquerade_rules() {
    local enable_ip6="$1"
    nft add rule ip "$NFT_TABLE" postrouting ct status dnat masquerade >/dev/null 2>&1 || return 1
    if [[ "$enable_ip6" == "1" ]]; then
        nft add rule ip6 "$NFT_TABLE" postrouting ct status dnat masquerade >/dev/null 2>&1 || return 1
    fi
    return 0
}

run_apply() {
    [[ "$(cat /proc/sys/net/ipv4/ip_forward 2>/dev/null)" != "1" ]] && \
        { echo 1 > /proc/sys/net/ipv4/ip_forward 2>/dev/null || return 1; }

    load_rules_for_apply
    setup_nft_family ip || return 1

    local need_ip6=0
    local i
    for ((i=0; i<${#rules_src_port[@]}; i++)); do
        is_valid_ipv6 "${rules_resolved_ip[$i]}" && { need_ip6=1; break; }
    done

    if [[ "$need_ip6" -eq 1 ]]; then
        setup_nft_family ip6 || return 1
    else
        cleanup_unused_ip6_table
    fi

    if [[ ${#rules_src_port[@]} -eq 0 ]]; then
        add_masquerade_rules "$need_ip6"; return $?
    fi

    local fail_count=0
    for ((i=0; i<${#rules_src_port[@]}; i++)); do
        local listen_ip="${rules_listen_ip[$i]}" src_port="${rules_src_port[$i]}"
        local dst_ip="${rules_resolved_ip[$i]}" dst_port="${rules_dst_port[$i]}"
        local proto="${rules_proto[$i]}"

        case "$proto" in
            tcp)  add_nft_rule "$listen_ip" "$src_port" "$dst_ip" "$dst_port" "tcp" || ((fail_count++)) ;;
            udp)  add_nft_rule "$listen_ip" "$src_port" "$dst_ip" "$dst_port" "udp" || ((fail_count++)) ;;
            both)
                add_nft_rule "$listen_ip" "$src_port" "$dst_ip" "$dst_port" "tcp" || ((fail_count++))
                add_nft_rule "$listen_ip" "$src_port" "$dst_ip" "$dst_port" "udp" || ((fail_count++))
                ;;
        esac
    done

    add_masquerade_rules "$need_ip6" || return 1
    [[ "$fail_count" -gt 0 ]] && { echo "[警告] 共 ${fail_count} 条规则应用失败" >&2; return 1; }
    return 0
}

run_watch() {
    [[ -f "$CONFIG_FILE" ]] || return 0
    read_global_watch_enabled
    [[ "$GLOBAL_WATCH_ENABLED" == "1" ]] || return 0
    [[ -t 1 ]] && MANUAL_MODE=1

    exec 200>"$LOCK_FILE"
    flock -n 200 || return 0

    local tmp_file now changed
    tmp_file=$(mktemp)
    now=$(date +%s)
    changed=0

    while IFS='|' read -r c1 c2 c3 c4 c5 c6 c7 c8 c9; do
        # 注释行 / 空行 / 全局设置行直接透传
        if [[ -z "$c1" || "$c1" == \#* || "$c1" =~ ^GLOBAL_ ]]; then
            echo "$c1${c2:+|$c2}${c3:+|$c3}${c4:+|$c4}${c5:+|$c5}${c6:+|$c6}${c7:+|$c7}${c8:+|$c8}${c9:+|$c9}" >> "$tmp_file"
            continue
        fi

        local listen_ip="$c1" src_port="$c2" dst_host="$c3" dst_port="$c4" proto="$c5"
        local resolved_ip="$c6" check_interval="$c7" last_check_ts="$c8" is_domain="$c9"

        [[ "$check_interval" =~ ^[0-9]+$ ]] || check_interval=0
        [[ "$last_check_ts" =~ ^[0-9]+$ ]] || last_check_ts=0

        if [[ "$is_domain" == "1" ]]; then
            [[ "$check_interval" -le 0 ]] && check_interval=300
            local need_check=0
            [[ "$MANUAL_MODE" -eq 1 ]] && need_check=1
            (( now - last_check_ts >= check_interval )) && need_check=1

            if [[ "$need_check" -eq 1 ]]; then
                local new_ip
                new_ip=$(resolve_domain_ip "$dst_host" 2>/dev/null || true)
                if is_valid_ip "$new_ip"; then
                    [[ "$MANUAL_MODE" -eq 1 ]] && echo "${dst_host} -> ${new_ip}"
                    if [[ "$new_ip" != "$resolved_ip" ]]; then
                        change_records+=("${dst_host}: ${resolved_ip} -> ${new_ip}")
                        resolved_ip="$new_ip"
                        changed=1
                    fi
                    last_check_ts="$now"
                fi
            fi
        fi

        echo "${listen_ip}|${src_port}|${dst_host}|${dst_port}|${proto}|${resolved_ip}|${check_interval}|${last_check_ts}|${is_domain}" >> "$tmp_file"
    done < "$CONFIG_FILE"

    if [[ "$changed" -eq 1 ]]; then
        cp "$tmp_file" "$CONFIG_FILE"
        if [[ "$MANUAL_MODE" -eq 0 ]]; then
            sleep 3
            local apply_cmd="$SCRIPT_SELF"
            [[ -x "$apply_cmd" ]] || apply_cmd="/usr/local/bin/iptables-forward"

            local apply_output apply_rc=0
            apply_output=$("$apply_cmd" --apply 2>&1) || apply_rc=$?
            if [[ "$apply_rc" -ne 0 ]]; then
                local one_line
                one_line=$(echo "$apply_output" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g' | cut -c1-500)
                log_watch "apply failed rc=${apply_rc} uid=${EUID} cmd='${apply_cmd} --apply' err='${one_line}'"
            fi

            local record
            for record in "${change_records[@]}"; do
                log_watch "IP changed: ${record}"
            done
        fi
    elif ! cmp -s "$tmp_file" "$CONFIG_FILE"; then
        cp "$tmp_file" "$CONFIG_FILE"
    fi

    rm -f "$tmp_file"
}

main() {
    local mode="apply"
    case "${1:-}" in
        --watch) mode="watch" ;;
        *) mode="apply" ;;
    esac

    if [[ "$EUID" -ne 0 ]]; then
        log_watch "insufficient privileges: uid=${EUID}, mode=${mode}"
        echo "[错误] 请使用 root 权限运行（uid=${EUID}, mode=${mode}）" >&2
        return 1
    fi

    if ! command -v nft >/dev/null 2>&1; then
        log_watch "nft command not found, mode=${mode}, PATH=${PATH}"
        echo "[错误] nft 未找到，请确认已安装 nftables 并可在当前 PATH 下执行" >&2
        return 1
    fi

    if [[ "$mode" == "watch" ]]; then
        run_watch
    else
        run_apply
    fi
}

main "$@"
