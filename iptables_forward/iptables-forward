#!/bin/bash

# ============================================================
#  端口转发统一脚本（apply + watch）
#  --apply : 读取 rules.conf 并重建转发规则
#  --watch : 解析域名并按需触发规则重建
#  后端优先级: nftables > iptables
# ============================================================

export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH}"

CONFIG_DIR="/etc/iptables-forward"
CONFIG_FILE="${CONFIG_DIR}/rules.conf"
LOCK_FILE="${CONFIG_DIR}/rules.conf.lock"
CHAIN_PRE="IPTFWD-PRE"
CHAIN_POST="IPTFWD-POST"
NFT_TABLE="portfwd"
SCRIPT_SELF="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || true)"

GLOBAL_WATCH_ENABLED=1
IP6_CHAINS_READY=0
MANUAL_MODE=0
BACKEND=""
change_records=()

log_watch() {
    command -v logger >/dev/null 2>&1 && logger -t iptables-forward "$1"
}

is_valid_ipv4() {
    local ip="$1"
    [[ "$ip" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]] || return 1
    IFS='.' read -r o1 o2 o3 o4 <<< "$ip"
    for o in "$o1" "$o2" "$o3" "$o4"; do
        [[ "$o" -ge 0 && "$o" -le 255 ]] || return 1
    done
    return 0
}

is_valid_ipv6() {
    [[ "$1" == *:* && "$1" =~ ^[0-9A-Fa-f:]+$ ]]
}

is_valid_ip() {
    is_valid_ipv4 "$1" || is_valid_ipv6 "$1"
}

read_global_watch_enabled() {
    [[ -f "$CONFIG_FILE" ]] || return 0
    local enabled
    enabled=$(grep -m1 '^GLOBAL_WATCH_ENABLED=' "$CONFIG_FILE" 2>/dev/null | cut -d'=' -f2)
    [[ "$enabled" == "0" || "$enabled" == "1" ]] && GLOBAL_WATCH_ENABLED="$enabled"
}

resolve_domain_ip() {
    local domain="$1" ip=""
    command -v dig >/dev/null 2>&1 || return 1

    local server type
    for server in 8.8.8.8 1.1.1.1; do
        for type in A AAAA; do
            ip=$(dig @"$server" "$type" "$domain" +short 2>/dev/null | head -n 1)
            if [[ "$type" == "A" ]]; then
                is_valid_ipv4 "$ip" && { echo "$ip"; return 0; }
            else
                is_valid_ipv6 "$ip" && { echo "$ip"; return 0; }
            fi
        done
    done
    return 1
}

parse_port_expr() {
    local expr="$1"
    if [[ "$expr" =~ ^[0-9]+$ ]]; then
        [[ "$expr" -ge 1 && "$expr" -le 65535 ]] && { echo "single|$expr|$expr"; return 0; }
        return 1
    fi
    if [[ "$expr" =~ ^([0-9]+)-([0-9]+)$ ]]; then
        local a="${BASH_REMATCH[1]}" b="${BASH_REMATCH[2]}"
        [[ "$a" -ge 1 && "$b" -le 65535 && "$a" -lt "$b" ]] && { echo "range|$a|$b"; return 0; }
        return 1
    fi
    return 1
}

# ---------- 后端检测 ----------
detect_backend() {
    if command -v nft >/dev/null 2>&1; then
        BACKEND="nft"
    elif command -v iptables >/dev/null 2>&1; then
        BACKEND="iptables"
    else
        log_watch "neither nft nor iptables found, PATH=${PATH}"
        echo "[错误] 未找到 nft 或 iptables，请确认已安装" >&2
        return 1
    fi
}

# ============================================================
#  nftables 后端
# ============================================================

nft_init_table() {
    # 创建 IPv4 表和链
    nft add table ip "$NFT_TABLE" 2>/dev/null
    nft flush table ip "$NFT_TABLE" 2>/dev/null
    nft "add chain ip ${NFT_TABLE} prerouting { type nat hook prerouting priority -100 ; }" 2>/dev/null
    nft "add chain ip ${NFT_TABLE} postrouting { type nat hook postrouting priority 100 ; }" 2>/dev/null
}

nft_init_table_ip6() {
    nft add table ip6 "$NFT_TABLE" 2>/dev/null
    nft flush table ip6 "$NFT_TABLE" 2>/dev/null
    nft "add chain ip6 ${NFT_TABLE} prerouting { type nat hook prerouting priority -100 ; }" 2>/dev/null
    nft "add chain ip6 ${NFT_TABLE} postrouting { type nat hook postrouting priority 100 ; }" 2>/dev/null
}

nft_add_dnat_rule() {
    local family="$1" listen_ip="$2" proto="$3" src_port="$4" dst_ip="$5" dst_port="$6"

    local src_meta dst_meta
    src_meta=$(parse_port_expr "$src_port") || return 1
    dst_meta=$(parse_port_expr "$dst_port") || return 1

    local src_type src_start src_end dst_type dst_start dst_end
    IFS='|' read -r src_type src_start src_end <<< "$src_meta"
    IFS='|' read -r dst_type dst_start dst_end <<< "$dst_meta"

    local dport_expr dnat_target
    if [[ "$src_type" == "single" ]]; then
        dport_expr="$src_start"
        dnat_target="${dst_ip}:${dst_start}"
    else
        # 端口段（源=目标）
        dport_expr="${src_start}-${src_end}"
        dnat_target="${dst_ip}:${dst_start}-${dst_end}"
    fi

    # IPv6 目标需要方括号
    if [[ "$family" == "ip6" ]]; then
        dnat_target="[${dst_ip}]:${dst_port}"
        if [[ "$src_type" == "single" ]]; then
            dnat_target="[${dst_ip}]:${dst_start}"
        else
            dnat_target="[${dst_ip}]:${dst_start}-${dst_end}"
        fi
    fi

    local addr_match=""
    if [[ "$family" == "ip" && "$listen_ip" != "0.0.0.0" ]]; then
        addr_match="ip daddr ${listen_ip}"
    elif [[ "$family" == "ip6" && "$listen_ip" != "::" ]]; then
        addr_match="ip6 daddr ${listen_ip}"
    fi

    local rule_cmd="add rule ${family} ${NFT_TABLE} prerouting ${addr_match} ${proto} dport ${dport_expr} dnat to ${dnat_target}"
    if ! nft ${rule_cmd} 2>/dev/null; then
        echo "[错误] nft 添加规则失败: ${rule_cmd}" >&2
        return 1
    fi
}

nft_add_masquerade() {
    local family="$1"
    nft add rule "${family}" "${NFT_TABLE}" postrouting ct status dnat masquerade 2>/dev/null || {
        echo "[错误] nft 添加 masquerade 失败 (${family})" >&2
        return 1
    }
}

nft_cleanup() {
    nft delete table ip "$NFT_TABLE" 2>/dev/null || true
    nft delete table ip6 "$NFT_TABLE" 2>/dev/null || true
}

# ---------- nft apply 用规则数组 ----------
nft_rules_listen_ip=()
nft_rules_src_port=()
nft_rules_dst_port=()
nft_rules_resolved_ip=()
nft_rules_proto=()

nft_load_rules() {
    [[ -f "$CONFIG_FILE" ]] || return 1

    nft_rules_listen_ip=(); nft_rules_src_port=(); nft_rules_dst_port=()
    nft_rules_resolved_ip=(); nft_rules_proto=()

    while IFS='|' read -r c1 c2 c3 c4 c5 c6 c7 c8 c9; do
        [[ -z "$c1" || "$c1" == \#* || "$c1" =~ ^GLOBAL_ ]] && continue

        local listen_ip src_port dst_port resolved proto

        if [[ -n "$c9" ]]; then
            listen_ip="$c1"; src_port="$c2"; dst_port="$c4"; proto="$c5"
            resolved="$c6"; is_valid_ip "$resolved" || resolved="$c3"
        elif [[ -n "$c5" ]]; then
            listen_ip="$c1"; src_port="$c2"; dst_port="$c4"; proto="$c5"; resolved="$c3"
        elif [[ -n "$c4" ]]; then
            listen_ip="0.0.0.0"; src_port="$c1"; dst_port="$c3"; proto="$c4"; resolved="$c2"
        else
            continue
        fi

        is_valid_ip "$resolved" || continue
        nft_rules_listen_ip+=("$listen_ip"); nft_rules_src_port+=("$src_port")
        nft_rules_dst_port+=("$dst_port"); nft_rules_resolved_ip+=("$resolved"); nft_rules_proto+=("$proto")
    done < "$CONFIG_FILE"
}

run_apply_nft() {
    [[ "$(cat /proc/sys/net/ipv4/ip_forward 2>/dev/null)" != "1" ]] && \
        { echo 1 > /proc/sys/net/ipv4/ip_forward 2>/dev/null || return 1; }

    nft_load_rules
    nft_init_table || return 1

    local has_ipv6=0

    if [[ ${#nft_rules_src_port[@]} -eq 0 ]]; then
        nft_add_masquerade "ip"
        return $?
    fi

    local fail_count=0
    for ((i=0; i<${#nft_rules_src_port[@]}; i++)); do
        local listen_ip="${nft_rules_listen_ip[$i]}" src_port="${nft_rules_src_port[$i]}"
        local dst_ip="${nft_rules_resolved_ip[$i]}" dst_port="${nft_rules_dst_port[$i]}"
        local proto="${nft_rules_proto[$i]}"

        local family="ip"
        if is_valid_ipv6 "$dst_ip"; then
            family="ip6"
            if [[ "$has_ipv6" -eq 0 ]]; then
                nft_init_table_ip6 || { ((fail_count++)); continue; }
                has_ipv6=1
            fi
        fi

        case "$proto" in
            tcp)  nft_add_dnat_rule "$family" "$listen_ip" "tcp" "$src_port" "$dst_ip" "$dst_port" || ((fail_count++)) ;;
            udp)  nft_add_dnat_rule "$family" "$listen_ip" "udp" "$src_port" "$dst_ip" "$dst_port" || ((fail_count++)) ;;
            both)
                nft_add_dnat_rule "$family" "$listen_ip" "tcp" "$src_port" "$dst_ip" "$dst_port" || ((fail_count++))
                nft_add_dnat_rule "$family" "$listen_ip" "udp" "$src_port" "$dst_ip" "$dst_port" || ((fail_count++))
                ;;
        esac
    done

    nft_add_masquerade "ip" || return 1
    [[ "$has_ipv6" -eq 1 ]] && { nft_add_masquerade "ip6" || return 1; }

    [[ "$fail_count" -gt 0 ]] && { echo "[警告] 共 ${fail_count} 条规则应用失败 (nft)" >&2; return 1; }
    return 0
}

# ============================================================
#  iptables 后端（备用）
# ============================================================

ensure_ip6_chains() {
    [[ "$IP6_CHAINS_READY" -eq 1 ]] && return 0
    command -v ip6tables >/dev/null 2>&1 || return 1

    ip6tables -t nat -N "$CHAIN_PRE" 2>/dev/null || ip6tables -t nat -F "$CHAIN_PRE"
    ip6tables -t nat -N "$CHAIN_POST" 2>/dev/null || ip6tables -t nat -F "$CHAIN_POST"
    ip6tables -t nat -C PREROUTING -j "$CHAIN_PRE" 2>/dev/null || ip6tables -t nat -A PREROUTING -j "$CHAIN_PRE"
    ip6tables -t nat -C POSTROUTING -j "$CHAIN_POST" 2>/dev/null || ip6tables -t nat -A POSTROUTING -j "$CHAIN_POST"

    IP6_CHAINS_READY=1
}

# ---------- iptables apply 用规则数组 ----------
ipt_rules_listen_ip=()
ipt_rules_src_port=()
ipt_rules_dst_port=()
ipt_rules_resolved_ip=()
ipt_rules_proto=()

ipt_load_rules() {
    [[ -f "$CONFIG_FILE" ]] || return 1

    ipt_rules_listen_ip=(); ipt_rules_src_port=(); ipt_rules_dst_port=()
    ipt_rules_resolved_ip=(); ipt_rules_proto=()

    while IFS='|' read -r c1 c2 c3 c4 c5 c6 c7 c8 c9; do
        [[ -z "$c1" || "$c1" == \#* || "$c1" =~ ^GLOBAL_ ]] && continue

        local listen_ip src_port dst_port resolved proto

        if [[ -n "$c9" ]]; then
            listen_ip="$c1"; src_port="$c2"; dst_port="$c4"; proto="$c5"
            resolved="$c6"; is_valid_ip "$resolved" || resolved="$c3"
        elif [[ -n "$c5" ]]; then
            listen_ip="$c1"; src_port="$c2"; dst_port="$c4"; proto="$c5"; resolved="$c3"
        elif [[ -n "$c4" ]]; then
            listen_ip="0.0.0.0"; src_port="$c1"; dst_port="$c3"; proto="$c4"; resolved="$c2"
        else
            continue
        fi

        is_valid_ip "$resolved" || continue
        ipt_rules_listen_ip+=("$listen_ip"); ipt_rules_src_port+=("$src_port")
        ipt_rules_dst_port+=("$dst_port"); ipt_rules_resolved_ip+=("$resolved"); ipt_rules_proto+=("$proto")
    done < "$CONFIG_FILE"
}

init_custom_chains() {
    iptables -t nat -N "$CHAIN_PRE" 2>/dev/null || iptables -t nat -F "$CHAIN_PRE"
    iptables -t nat -N "$CHAIN_POST" 2>/dev/null || iptables -t nat -F "$CHAIN_POST"
    iptables -t nat -C PREROUTING -j "$CHAIN_PRE" 2>/dev/null || iptables -t nat -A PREROUTING -j "$CHAIN_PRE"
    iptables -t nat -C POSTROUTING -j "$CHAIN_POST" 2>/dev/null || iptables -t nat -A POSTROUTING -j "$CHAIN_POST"
}

add_masquerade_rules() {
    iptables -t nat -A "$CHAIN_POST" -m conntrack --ctstate DNAT -j MASQUERADE || return 1
    if [[ "$IP6_CHAINS_READY" -eq 1 ]]; then
        ip6tables -t nat -A "$CHAIN_POST" -m conntrack --ctstate DNAT -j MASQUERADE 2>/dev/null || return 1
    fi
}

add_single_iptables_rule() {
    local ip_cmd="$1" listen_ip="$2" proto="$3" dport="$4" dnat_target="$5"
    if [[ "$listen_ip" == "0.0.0.0" || ( "$listen_ip" == "::" && "$ip_cmd" == "ip6tables" ) ]]; then
        "$ip_cmd" -t nat -A "$CHAIN_PRE" -p "$proto" --dport "$dport" -j DNAT --to-destination "$dnat_target" || \
            echo "[错误] 添加规则失败: ${listen_ip} ${dport} -> ${dnat_target} (${proto})" >&2
    else
        "$ip_cmd" -t nat -A "$CHAIN_PRE" -d "$listen_ip" -p "$proto" --dport "$dport" -j DNAT --to-destination "$dnat_target" || \
            echo "[错误] 添加规则失败: ${listen_ip} ${dport} -> ${dnat_target} (${proto})" >&2
    fi
}

add_iptables_rule() {
    local listen_ip="$1" src_port="$2" dst_ip="$3" dst_port="$4" proto="$5"

    local ip_cmd="iptables" dst_target_ip="$dst_ip"
    if is_valid_ipv6 "$dst_ip"; then
        ensure_ip6_chains || return 1
        ip_cmd="ip6tables"; dst_target_ip="[$dst_ip]"
    fi

    local src_meta dst_meta
    src_meta=$(parse_port_expr "$src_port") || return 1
    dst_meta=$(parse_port_expr "$dst_port") || return 1

    local src_type src_start src_end dst_type dst_start dst_end
    IFS='|' read -r src_type src_start src_end <<< "$src_meta"
    IFS='|' read -r dst_type dst_start dst_end <<< "$dst_meta"

    # 单端口 → 单端口，或端口段相同
    local src_dport="${src_port//-/:}"
    add_single_iptables_rule "$ip_cmd" "$listen_ip" "$proto" "$src_dport" "${dst_target_ip}:${dst_port}"
}

run_apply_iptables() {
    [[ "$(cat /proc/sys/net/ipv4/ip_forward 2>/dev/null)" != "1" ]] && \
        { echo 1 > /proc/sys/net/ipv4/ip_forward 2>/dev/null || return 1; }

    ipt_load_rules
    init_custom_chains || return 1

    if [[ ${#ipt_rules_src_port[@]} -eq 0 ]]; then
        add_masquerade_rules; return $?
    fi

    local fail_count=0
    for ((i=0; i<${#ipt_rules_src_port[@]}; i++)); do
        local listen_ip="${ipt_rules_listen_ip[$i]}" src_port="${ipt_rules_src_port[$i]}"
        local dst_ip="${ipt_rules_resolved_ip[$i]}" dst_port="${ipt_rules_dst_port[$i]}"
        local proto="${ipt_rules_proto[$i]}"

        case "$proto" in
            tcp)  add_iptables_rule "$listen_ip" "$src_port" "$dst_ip" "$dst_port" "tcp" || ((fail_count++)) ;;
            udp)  add_iptables_rule "$listen_ip" "$src_port" "$dst_ip" "$dst_port" "udp" || ((fail_count++)) ;;
            both)
                add_iptables_rule "$listen_ip" "$src_port" "$dst_ip" "$dst_port" "tcp" || ((fail_count++))
                add_iptables_rule "$listen_ip" "$src_port" "$dst_ip" "$dst_port" "udp" || ((fail_count++))
                ;;
        esac
    done

    add_masquerade_rules || return 1
    [[ "$fail_count" -gt 0 ]] && { echo "[警告] 共 ${fail_count} 条规则应用失败 (iptables)" >&2; return 1; }
    return 0
}

# ============================================================
#  统一 apply 入口
# ============================================================

run_apply() {
    detect_backend || return 1

    if [[ "$BACKEND" == "nft" ]]; then
        run_apply_nft
    else
        run_apply_iptables
    fi
}

# ============================================================
#  watch 模式（域名解析监控）
# ============================================================

run_watch() {
    [[ -f "$CONFIG_FILE" ]] || return 0
    read_global_watch_enabled
    [[ "$GLOBAL_WATCH_ENABLED" == "1" ]] || return 0
    [[ -t 1 ]] && MANUAL_MODE=1

    exec 200>"$LOCK_FILE"
    flock -n 200 || return 0

    local tmp_file now changed
    tmp_file=$(mktemp)
    now=$(date +%s)
    changed=0

    while IFS='|' read -r c1 c2 c3 c4 c5 c6 c7 c8 c9; do
        # 注释行 / 空行 / 全局设置行直接透传
        if [[ -z "$c1" || "$c1" == \#* || "$c1" =~ ^GLOBAL_ ]]; then
            echo "$c1${c2:+|$c2}${c3:+|$c3}${c4:+|$c4}${c5:+|$c5}${c6:+|$c6}${c7:+|$c7}${c8:+|$c8}${c9:+|$c9}" >> "$tmp_file"
            continue
        fi

        local listen_ip="$c1" src_port="$c2" dst_host="$c3" dst_port="$c4" proto="$c5"
        local resolved_ip="$c6" check_interval="$c7" last_check_ts="$c8" is_domain="$c9"

        [[ "$check_interval" =~ ^[0-9]+$ ]] || check_interval=0
        [[ "$last_check_ts" =~ ^[0-9]+$ ]] || last_check_ts=0

        if [[ "$is_domain" == "1" ]]; then
            [[ "$check_interval" -le 0 ]] && check_interval=300
            local need_check=0
            [[ "$MANUAL_MODE" -eq 1 ]] && need_check=1
            (( now - last_check_ts >= check_interval )) && need_check=1

            if [[ "$need_check" -eq 1 ]]; then
                local new_ip
                new_ip=$(resolve_domain_ip "$dst_host" 2>/dev/null || true)
                if is_valid_ip "$new_ip"; then
                    [[ "$MANUAL_MODE" -eq 1 ]] && echo "${dst_host} -> ${new_ip}"
                    if [[ "$new_ip" != "$resolved_ip" ]]; then
                        change_records+=("${dst_host}: ${resolved_ip} -> ${new_ip}")
                        resolved_ip="$new_ip"
                        changed=1
                    fi
                    last_check_ts="$now"
                fi
            fi
        fi

        echo "${listen_ip}|${src_port}|${dst_host}|${dst_port}|${proto}|${resolved_ip}|${check_interval}|${last_check_ts}|${is_domain}" >> "$tmp_file"
    done < "$CONFIG_FILE"

    if [[ "$changed" -eq 1 ]]; then
        cp "$tmp_file" "$CONFIG_FILE"
        if [[ "$MANUAL_MODE" -eq 0 ]]; then
            sleep 3
            local apply_cmd="$SCRIPT_SELF"
            [[ -x "$apply_cmd" ]] || apply_cmd="/usr/local/bin/iptables-forward"

            local apply_output apply_rc=0
            apply_output=$("$apply_cmd" --apply 2>&1) || apply_rc=$?
            if [[ "$apply_rc" -ne 0 ]]; then
                local one_line
                one_line=$(echo "$apply_output" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g' | cut -c1-500)
                log_watch "apply failed rc=${apply_rc} uid=${EUID} cmd='${apply_cmd} --apply' err='${one_line}'"
            fi

            local record
            for record in "${change_records[@]}"; do
                log_watch "IP changed: ${record}"
            done
        fi
    elif ! cmp -s "$tmp_file" "$CONFIG_FILE"; then
        cp "$tmp_file" "$CONFIG_FILE"
    fi

    rm -f "$tmp_file"
}

# ============================================================
#  主入口
# ============================================================

main() {
    local mode="apply"
    case "${1:-}" in
        --watch) mode="watch" ;;
        *) mode="apply" ;;
    esac

    if [[ "$EUID" -ne 0 ]]; then
        log_watch "insufficient privileges: uid=${EUID}, mode=${mode}"
        echo "[错误] 请使用 root 权限运行（uid=${EUID}, mode=${mode}）" >&2
        return 1
    fi

    detect_backend || {
        echo "[错误] 未找到 nft 或 iptables，请确认已安装并可在当前 PATH 下执行" >&2
        return 1
    }

    if [[ "$mode" == "watch" ]]; then
        run_watch
    else
        run_apply
    fi
}

main "$@"
