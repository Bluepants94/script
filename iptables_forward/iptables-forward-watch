#!/bin/bash
CONFIG_FILE="/etc/iptables-forward/rules.conf"
LOCK_FILE="/etc/iptables-forward/rules.conf.lock"
CHAIN_PRE="IPTFWD-PRE"

GLOBAL_WATCH_ENABLED=1
change_records=()
change_listen_ips=()
change_src_ports=()
change_dst_ports=()
change_protos=()
change_old_ips=()
change_new_ips=()

parse_port_expr() {
    local expr="$1"
    if [[ "$expr" =~ ^[0-9]+$ ]]; then
        if [[ "$expr" -ge 1 && "$expr" -le 65535 ]]; then
            echo "single|$expr|$expr"
            return 0
        fi
        return 1
    fi

    if [[ "$expr" =~ ^([0-9]+)-([0-9]+)$ ]]; then
        local a="${BASH_REMATCH[1]}"
        local b="${BASH_REMATCH[2]}"
        if [[ "$a" -ge 1 && "$b" -le 65535 && "$a" -lt "$b" ]]; then
            echo "range|$a|$b"
            return 0
        fi
    fi

    return 1
}

to_iptables_dport() {
    echo "$1" | sed 's/-/:/'
}

apply_single_rule() {
    local action="$1"      # -A / -D
    local listen_ip="$2"
    local src_port="$3"
    local dst_ip="$4"
    local dst_port="$5"
    local proto="$6"

    local src_meta dst_meta
    src_meta=$(parse_port_expr "$src_port") || return 1
    dst_meta=$(parse_port_expr "$dst_port") || return 1

    local src_type src_start src_end dst_type dst_start dst_end
    IFS='|' read -r src_type src_start src_end <<< "$src_meta"
    IFS='|' read -r dst_type dst_start dst_end <<< "$dst_meta"

    if [[ "$src_type" == "single" && "$dst_type" == "single" ]]; then
        local src_dport dst_dport
        src_dport=$(to_iptables_dport "$src_port")
        dst_dport=$(to_iptables_dport "$dst_port")
        if [[ "$listen_ip" == "0.0.0.0" ]]; then
            iptables -t nat "$action" "$CHAIN_PRE" -p "$proto" --dport "$src_dport" -j DNAT --to-destination "${dst_ip}:${dst_dport}" >/dev/null 2>&1 || true
        else
            iptables -t nat "$action" "$CHAIN_PRE" -d "$listen_ip" -p "$proto" --dport "$src_dport" -j DNAT --to-destination "${dst_ip}:${dst_dport}" >/dev/null 2>&1 || true
        fi
        return 0
    fi

    if [[ "$src_type" == "range" && "$dst_type" == "range" ]]; then
        if [[ "$src_start" == "$dst_start" && "$src_end" == "$dst_end" ]]; then
            local src_dport dst_dport
            src_dport=$(to_iptables_dport "$src_port")
            dst_dport=$(to_iptables_dport "$dst_port")
            if [[ "$listen_ip" == "0.0.0.0" ]]; then
                iptables -t nat "$action" "$CHAIN_PRE" -p "$proto" --dport "$src_dport" -j DNAT --to-destination "${dst_ip}:${dst_dport}" >/dev/null 2>&1 || true
            else
                iptables -t nat "$action" "$CHAIN_PRE" -d "$listen_ip" -p "$proto" --dport "$src_dport" -j DNAT --to-destination "${dst_ip}:${dst_dport}" >/dev/null 2>&1 || true
            fi
            return 0
        fi

        local src_len=$(( src_end - src_start + 1 ))
        [[ "$src_len" -le 1000 ]] || return 1

        for ((offset=0; offset<src_len; offset++)); do
            local sp=$((src_start + offset))
            local dp=$((dst_start + offset))
            if [[ "$listen_ip" == "0.0.0.0" ]]; then
                iptables -t nat "$action" "$CHAIN_PRE" -p "$proto" --dport "$sp" -j DNAT --to-destination "${dst_ip}:${dp}" >/dev/null 2>&1 || true
            else
                iptables -t nat "$action" "$CHAIN_PRE" -d "$listen_ip" -p "$proto" --dport "$sp" -j DNAT --to-destination "${dst_ip}:${dp}" >/dev/null 2>&1 || true
            fi
        done
        return 0
    fi

    return 1
}

update_changed_rule_iptables() {
    local listen_ip="$1"
    local src_port="$2"
    local dst_port="$3"
    local proto="$4"
    local old_ip="$5"
    local new_ip="$6"

    case "$proto" in
        tcp)
            apply_single_rule "-D" "$listen_ip" "$src_port" "$old_ip" "$dst_port" "tcp"
            apply_single_rule "-A" "$listen_ip" "$src_port" "$new_ip" "$dst_port" "tcp"
            ;;
        udp)
            apply_single_rule "-D" "$listen_ip" "$src_port" "$old_ip" "$dst_port" "udp"
            apply_single_rule "-A" "$listen_ip" "$src_port" "$new_ip" "$dst_port" "udp"
            ;;
        both)
            apply_single_rule "-D" "$listen_ip" "$src_port" "$old_ip" "$dst_port" "tcp"
            apply_single_rule "-D" "$listen_ip" "$src_port" "$old_ip" "$dst_port" "udp"
            apply_single_rule "-A" "$listen_ip" "$src_port" "$new_ip" "$dst_port" "tcp"
            apply_single_rule "-A" "$listen_ip" "$src_port" "$new_ip" "$dst_port" "udp"
            ;;
    esac
}

read_global_watch_enabled() {
    [[ -f "$CONFIG_FILE" ]] || return 0
    local enabled
    enabled=$(grep -m1 '^GLOBAL_WATCH_ENABLED=' "$CONFIG_FILE" 2>/dev/null | cut -d'=' -f2)
    if [[ "$enabled" == "0" || "$enabled" == "1" ]]; then
        GLOBAL_WATCH_ENABLED="$enabled"
    fi
}

is_ipv4() {
    local ip="$1"
    [[ "$ip" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]] || return 1
    IFS='.' read -r o1 o2 o3 o4 <<< "$ip"
    for o in "$o1" "$o2" "$o3" "$o4"; do
        [[ "$o" -ge 0 && "$o" -le 255 ]] || return 1
    done
    return 0
}

resolve_domain_ipv4() {
    local domain="$1"
    local ip=""

    if command -v dig >/dev/null 2>&1; then
        # 过滤 CNAME，只取 IPv4 格式的行
        ip=$(dig @1.1.1.1 +short A "$domain" 2>/dev/null | grep -oE '^([0-9]{1,3}\.){3}[0-9]{1,3}$' | head -n 1)
        if is_ipv4 "$ip"; then
            echo "$ip"
            return 0
        fi

        ip=$(dig @1.0.0.1 +short A "$domain" 2>/dev/null | grep -oE '^([0-9]{1,3}\.){3}[0-9]{1,3}$' | head -n 1)
        if is_ipv4 "$ip"; then
            echo "$ip"
            return 0
        fi

        ip=$(dig @8.8.8.8 +short A "$domain" 2>/dev/null | grep -oE '^([0-9]{1,3}\.){3}[0-9]{1,3}$' | head -n 1)
        if is_ipv4 "$ip"; then
            echo "$ip"
            return 0
        fi

        ip=$(dig @8.8.4.4 +short A "$domain" 2>/dev/null | grep -oE '^([0-9]{1,3}\.){3}[0-9]{1,3}$' | head -n 1)
        if is_ipv4 "$ip"; then
            echo "$ip"
            return 0
        fi
    fi

    ip=$(curl -s --max-time 5 "https://cloudflare-dns.com/dns-query?name=${domain}&type=A" \
        -H 'accept: application/dns-json' 2>/dev/null \
        | grep -oE '"data":"([0-9]{1,3}\.){3}[0-9]{1,3}"' \
        | head -n 1 \
        | sed -E 's/"data":"([0-9.]+)"/\1/')
    if is_ipv4 "$ip"; then
        echo "$ip"
        return 0
    fi

    ip=$(curl -s --max-time 5 "https://dns.google/resolve?name=${domain}&type=A" 2>/dev/null \
        | grep -oE '"data":"([0-9]{1,3}\.){3}[0-9]{1,3}"' \
        | head -n 1 \
        | sed -E 's/"data":"([0-9.]+)"/\1/')
    if is_ipv4 "$ip"; then
        echo "$ip"
        return 0
    fi

    return 1
}

[[ -f "$CONFIG_FILE" ]] || exit 0
read_global_watch_enabled
[[ "$GLOBAL_WATCH_ENABLED" == "1" ]] || exit 0

# 文件锁：防止与主脚本或其他实例同时写配置文件
exec 200>"$LOCK_FILE"
if ! flock -n 200; then
    command -v logger >/dev/null 2>&1 && logger -t iptables-forward-watch "another instance is running, skipping"
    exit 0
fi

tmp_file=$(mktemp)
now=$(date +%s)
changed=0

while IFS='|' read -r c1 c2 c3 c4 c5 c6 c7 c8 c9; do
    if [[ -z "$c1" || "$c1" == \#* ]]; then
        echo "$c1${c2:+|$c2}${c3:+|$c3}${c4:+|$c4}${c5:+|$c5}${c6:+|$c6}${c7:+|$c7}${c8:+|$c8}${c9:+|$c9}" >> "$tmp_file"
        continue
    fi

    if [[ "$c1" =~ ^GLOBAL_WATCH_ENABLED= ]] || [[ "$c1" =~ ^GLOBAL_WATCH_INTERVAL_MINUTES= ]] || [[ "$c1" =~ ^GLOBAL_RESTART_INTERVAL_MINUTES= ]]; then
        echo "$c1${c2:+|$c2}${c3:+|$c3}${c4:+|$c4}${c5:+|$c5}${c6:+|$c6}${c7:+|$c7}${c8:+|$c8}${c9:+|$c9}" >> "$tmp_file"
        continue
    fi

    listen_ip="$c1"
    src_port="$c2"
    dst_host="$c3"
    dst_port="$c4"
    proto="$c5"
    resolved_ip="$c6"
    check_interval="$c7"
    last_check_ts="$c8"
    is_domain="$c9"

    [[ "$check_interval" =~ ^[0-9]+$ ]] || check_interval=0
    [[ "$last_check_ts" =~ ^[0-9]+$ ]] || last_check_ts=0

    if [[ "$is_domain" == "1" ]]; then
        [[ "$check_interval" -le 0 ]] && check_interval=300
        if (( now - last_check_ts >= check_interval )); then
            new_ip=$(resolve_domain_ipv4 "$dst_host" 2>/dev/null || true)
            if is_ipv4 "$new_ip"; then
                if [[ "$new_ip" != "$resolved_ip" ]]; then
                    old_ip="$resolved_ip"
                    resolved_ip="$new_ip"
                    changed=1
                    change_records+=("${dst_host}: ${old_ip} -> ${new_ip}")
                    change_listen_ips+=("${listen_ip}")
                    change_src_ports+=("${src_port}")
                    change_dst_ports+=("${dst_port}")
                    change_protos+=("${proto}")
                    change_old_ips+=("${old_ip}")
                    change_new_ips+=("${new_ip}")
                fi
                last_check_ts="$now"
            fi
        fi
    fi

    echo "${listen_ip}|${src_port}|${dst_host}|${dst_port}|${proto}|${resolved_ip}|${check_interval}|${last_check_ts}|${is_domain}" >> "$tmp_file"
done < "$CONFIG_FILE"

if [[ "$changed" -eq 1 ]]; then
    # IP 发生变化：直接写入新配置并仅更新对应规则
    cp "$tmp_file" "$CONFIG_FILE"

    for ((i=0; i<${#change_records[@]}; i++)); do
        update_changed_rule_iptables \
            "${change_listen_ips[$i]}" \
            "${change_src_ports[$i]}" \
            "${change_dst_ports[$i]}" \
            "${change_protos[$i]}" \
            "${change_old_ips[$i]}" \
            "${change_new_ips[$i]}"
    done

    # 日志仅记录 IP 更变
    if command -v logger >/dev/null 2>&1; then
        for record in "${change_records[@]}"; do
            logger -t iptables-forward-watch "IP changed: ${record}"
        done
    fi
elif ! cmp -s "$tmp_file" "$CONFIG_FILE"; then
    # 仅时间戳等非关键字段变化，静默更新配置文件（不触发 apply）
    cp "$tmp_file" "$CONFIG_FILE"
fi

rm -f "$tmp_file"
