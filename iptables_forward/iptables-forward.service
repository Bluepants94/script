[Unit]
Description=nftables Port Forwarding Rules
After=network.target network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/local/bin/iptables-forward
RemainAfterExit=yes
StandardOutput=journal
StandardError=journal
SyslogIdentifier=nftables-forward

[Install]
WantedBy=multi-user.target
